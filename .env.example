# ============================================================
# REQUIRED
# ============================================================

# Get your Kuest CLOB Auth credentials by connecting your EVM wallet (Polygon, 0x...) at https://auth.kuest.com
KUEST_ADDRESS=""
KUEST_API_KEY=""
KUEST_API_SECRET=""
KUEST_PASSPHRASE=""

# Admin wallets (comma-separated, EVM 0x... addresses on Polygon)
ADMIN_WALLETS=""

# Public site URL, used for canonical links, wallet metadata, embeds, and callbacks
SITE_URL=""

# Your REOWN APPKIT project id http://dashboard.reown.com/
REOWN_APPKIT_PROJECT_ID=""

# Random 32 characters – generate one on "generate secret" button https://www.better-auth.com/docs/installation#set-environment-variables
# Changing this value will invalidate all user sessions AND encrypted credentials, requiring users to log in and re-authenticate for trading.
BETTER_AUTH_SECRET=""

# Vercel Cron Jobs (Create a random secret of at least 16 characters)
CRON_SECRET=""

# ============================================================
# OPTIONAL
# ============================================================

# Disable Next.js image optimization
DISABLE_IMAGE_OPTIMIZATION=false

# Optional RPC endpoint used for on-chain reads in the app
POLYGON_RPC_URL=""

# Force public shell prerendering on/off at runtime.
# Leave empty to infer from SITE_URL/VERCEL_PROJECT_PRODUCTION_URL + POSTGRES_URL + REOWN_APPKIT_PROJECT_ID.
BUILD_PRERENDER_PUBLIC_SHELL=""

# PostgreSQL runtime connection (required outside Vercel/Supabase integration flow)
POSTGRES_URL=""

# Supabase credentials (optional outside Supabase mode; if one is set, both are required)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# S3-compatible storage (required when SUPABASE_* is not configured)
S3_BUCKET=""
S3_ENDPOINT=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""
S3_FORCE_PATH_STYLE=true

# Sentry monitoring https://sentry.io/
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Private keys used to sign recurring event creations
# Format: comma-separated list of private keys no spaces (eg. key1,key2,key3)
EVENT_CREATION_SIGNER_PRIVATE_KEYS=
